# ============================================================
# Le Centre F - Configuration Backend
# ============================================================
# Copiez ce fichier en .env et remplissez les valeurs

# API Claude (Anthropic) - Obtenez votre clé sur console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-VOTRE-CLE-ICI

# Modèle Claude à utiliser
CLAUDE_MODEL=claude-sonnet-4-20250514

# Base de données PostgreSQL (avec extension pgvector installée)
DATABASE_URL=postgresql://centref:motdepasse@localhost:5432/centref_ai

# Modèle d'embeddings (multilingue pour le français)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Paramètres RAG
CHUNK_SIZE=600
CHUNK_OVERLAP=100
TOP_K_RESULTS=5

# Sécurité
SECRET_KEY=changez-moi-en-production-avec-une-clef-de-64-caracteres-minimum
ACCESS_TOKEN_EXPIRE_MINUTES=1440
